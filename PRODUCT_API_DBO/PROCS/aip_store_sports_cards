CREATE OR REPLACE PROCEDURE PRODUCT_API_DBO.aip_store_sports_cards(p_card_id_i         VARCHAR(300),
                                                                p_player_name_i     VARCHAR(60),
                                                                p_rookie_i		   BOOLEAN,
                                                                p_autograph_cd_i	   VARCHAR(15),
                                                                p_patch_i		    VARCHAR(30),
                                                                p_patch_color_cnt_i	INTEGER,
                                                                p_team_i				VARCHAR(60),
                                                                p_numbered_i			VARCHAR(15),
                                                                p_sport_type_cd_i	VARCHAR(30),
                                                                p_product_cd_i		VARCHAR(30),
                                                                p_img_link_i			VARCHAR(300),
                                                                p_variant_i			BOOLEAN,
                                                                p_grade_type_i		VARCHAR(30),
                                                                p_grade_score_i		DECIMAL(3, 1),
                                                                p_msrp_i				DECIMAL(10, 2),
                                                                p_cost_price_i		DECIMAL(10, 2),
                                                                p_sale_price_i		DECIMAL(10, 2))
AS $$
BEGIN
  INSERT INTO PRODUCT_DBO.SPORTS_CARDS(CARD_ID,
                                        PLAYER_NAME,
                                        ROOKIE,
                                        AUTOGRAPH_CD,
                                        PATCH,
                                        PATCH_COLOR_CNT,
                                        TEAM,
                                        NUMBERED,
                                        SPORT_TYPE_CD,
                                        PRODUCT_CD,
                                        IMG_LINK,
                                        VARIANT,
                                        GRADE_TYPE,
                                        GRADE_SCORE,
                                        MSRP,
                                        COST_PRICE,
                                        SALE_PRICE,
                                        CREATE_ID,
                                        CREATE_TS)
                                VALUES (p_card_id_i,
                                        p_player_name_i,
                                        p_rookie_i,
                                        p_autograph_cd_i,
                                        p_patch_i,
                                        p_color_cnt_i,
                                        p_team_i,
                                        p_numbered_i,
                                        p_sport_type_cd_i,
                                        p_product_cd_i,
                                        p_img_link_i,
                                        p_variant_i,
                                        p_grade_type_i,
                                        p_grade_score_i,
                                        p_msrp_i,
                                        p_cost_price_i,
                                        p_sale_price_i,
                                        CURRENT_USER,
                                        CURRENT_TIMESTAMP);
EXCEPTION 
      WHEN OTHERS THEN
        RAISE EXCEPTION 'Error in procedure product_api_dbo.aip_store_sports_cards (%)', SQLERRM;
END;
$$ LANGUAGE plpgsql;